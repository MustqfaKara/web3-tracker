OPENSEA_API_KEY=your_opensea_api_key

# Collection Tracking Toggles (on/off)
TRACK_4THEREACTOR=on
TRACK_SLONKS=on

# Optional: macOS desktop notification title.
NOTIFICATION_TITLE=NFT Listing

WATCH_MODE=poll
POLL_INTERVAL_MS=2000
POLL_BACKOFF_MS=10000
EVENT_LOOKBACK_SECONDS=300
ACTIVE_LISTING_SWEEP=true
LISTING_LOOKBACK_SECONDS=3600
OPEN_IN_CHROME=true

# Telegram notifications. Fill these to enable.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_SEND_PHOTO=false

# Wallet Tracker Settings
WALLET_ADDRESS=your_wallet_address
ALCHEMY_API_KEY=your_alchemy_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
WALLET_POLL_INTERVAL_MS=60000
