# =====================
# OpenSea
# =====================
OPENSEA_API_KEY=
# Tum OpenSea istekleri arasi minimum bekleme (queue throttle, default 400ms)
OPENSEA_MIN_GAP_MS=400

# =====================
# Genel davranis
# =====================
NOTIFICATION_TITLE=Listing Alert
# auto: once stream dene, hatada poll'a gec | stream: zorunlu stream | poll: REST polling
WATCH_MODE=auto
# Polling modunda istekler arasi sure (ms). Cok dusuk = 429
POLL_INTERVAL_MS=5000
# 429 alindiginda exponential backoff baslangic suresi
POLL_BACKOFF_MS=15000
# Dis API istekleri icin timeout (ms)
FETCH_TIMEOUT_MS=15000
# Stream'de bu sure event gelmezse poll'a fallback (ms)
STREAM_HEARTBEAT_TIMEOUT_MS=300000
# Event lookback window (saniye)
EVENT_LOOKBACK_SECONDS=300
# Aktif listing'lerin ne kadar eski olabilecegi
LISTING_LOOKBACK_SECONDS=3600
# Olaylara ek olarak aktif listing'leri de tara
ACTIVE_LISTING_SWEEP=true
# Eslesen NFT bulununca OpenSea sayfasini Chrome'da ac (macOS)
OPEN_IN_CHROME=true
# Lokal web dashboard
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787

# =====================
# Koleksiyon toggle'lari
# TRACK_<SLUG>=on/off (dash'ler underscore'a cevrilir: 365-703882509 -> TRACK_365_703882509)
# =====================
TRACK_FERRYMANURNS=on
TRACK_SATOS=on
TRACK_BACKPUNKS=off

# =====================
# Telegram
# =====================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_PHOTO=false
# Forum topic ID'leri - her bildirim turu kendi topic'ine duser
TELEGRAM_NFT_THREAD_ID=
TELEGRAM_COIN_THREAD_ID=
TELEGRAM_WALLET_THREAD_ID=
TELEGRAM_HEARTBEAT_THREAD_ID=
# Bot basladi/status/hata/heartbeat bilgileri icin topic
TELEGRAM_BOT_INFO_THREAD_ID=427

# =====================
# Cuzdan takibi
# =====================
# Virgulle ayrilmis cuzdan adresleri (multi-wallet destekli)
WALLET_ADDRESS=
# Base (L2) icin Alchemy API anahtari
ALCHEMY_API_KEY=
# Ethereum (L1) icin Etherscan v2 API anahtari
ETHERSCAN_API_KEY=
# Cuzdanlari kac saniyede bir polle (ms)
WALLET_POLL_INTERVAL_MS=60000
# Bu USD degerinin altindaki transferleri filtrele (dust filter)
MIN_USD_VALUE=0.01

# Cuzdan ismi override'lari (Telegram mesajinda gosterilen ad):
# WALLET_NAME_0x7befc9c1e5d399404c384b0bc58925228d57aa22=zeyt wallet

# =====================
# Background jobs
# =====================
# Her gun saat kacta heartbeat ozeti gonderilsin (0-23)
HEARTBEAT_HOUR=9
# Hata ozeti gonderim sikligi (ms)
ERROR_SUMMARY_INTERVAL_MS=3600000
# Bot info topic'ine canlilik/status gonderim sikligi (ms) — default 10 dakika
BOT_INFO_INTERVAL_MS=600000

# =====================
# Mod ayarlari
# =====================
# Bildirim gondermez, sadece log basar (test icin)
DRY_RUN=false
# Verbose log
DEBUG=false
